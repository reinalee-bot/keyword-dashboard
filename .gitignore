# ====================================================
# 절대 GitHub에 올리면 안 되는 파일 (비밀 정보)
# ====================================================

# 네이버 API 키가 들어있는 파일
.env

# Streamlit 로컬 비밀 설정 (GitHub 토큰 포함)
.streamlit/secrets.toml

# 구글 클라우드 키 파일 (혹시 나중에 생겨도 자동 제외)
credentials.json

# ====================================================
# 데이터베이스·백업 (로컬 전용)
# ====================================================
*.db

# ====================================================
# 파이썬 자동 생성 임시 파일
# ====================================================
__pycache__/
*.pyc
*.pyo

# ====================================================
# 로그 파일
# ====================================================
logs/
*.log

# ====================================================
# 일회성 유틸리티 스크립트 (올릴 필요 없음)
# ====================================================
_migrate_csv.py
_verify.py

# ====================================================
# 엑셀·xlsx 내보내기 결과물
# ====================================================
data/*.xlsx
KPI_*.xlsx
